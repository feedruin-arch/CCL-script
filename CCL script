-- ─── 1. BLINK (Q) ───
local blinkEnabled = false
local blinkKey = Enum.KeyCode.Q
local blinkDistance = 40
local blinkCooldown = false

MakeToggle("⚡ Blink [Q]", function(state)
    blinkEnabled = state
end)
MakeSlider("Blink Distance", 10, 150, 40, function(val)
    blinkDistance = val
end)

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if not blinkEnabled then return end
    if input.KeyCode ~= blinkKey then return end
    if blinkCooldown then return end

    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end

    blinkCooldown = true

    -- Ghost trail
    local lookVec = hrp.CFrame.LookVector
    for i = 1, 5 do
        local ghost = Instance.new("Part")
        ghost.Size = hrp.Size
        ghost.CFrame = hrp.CFrame + lookVec * (blinkDistance * (i / 5))
        ghost.Anchored = true
        ghost.CanCollide = false
        ghost.CastShadow = false
        ghost.Material = Enum.Material.Neon
        ghost.Color = Color3.fromRGB(160, 100, 255)
        ghost.Transparency = 0.4 + (i * 0.1)
        ghost.Parent = workspace
        game:GetService("Debris"):AddItem(ghost, 0.25)
    end

    -- Телепорт без заморозки
    local targetCFrame = hrp.CFrame + lookVec * blinkDistance
    hrp.CFrame = targetCFrame
    hum:ChangeState(Enum.HumanoidStateType.Running)

    -- Flash эффект
    local flash = Instance.new("Frame")
    flash.Size = UDim2.new(1, 0, 1, 0)
    flash.BackgroundColor3 = Color3.fromRGB(160, 100, 255)
    flash.BackgroundTransparency = 0.5
    flash.BorderSizePixel = 0
    flash.ZIndex = 100
    flash.Parent = ScreenGui
    TweenService:Create(flash, TweenInfo.new(0.2), {
        BackgroundTransparency = 1
    }):Play()
    game:GetService("Debris"):AddItem(flash, 0.25)

    task.wait(0.4)
    blinkCooldown = false
end)

